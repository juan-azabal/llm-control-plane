# OpenAI API key (required for gpt-4o-mini and gpt-4o models)
OPENAI_API_KEY=sk-your-openai-key-here

# LiteLLM master key (admin access to the gateway)
LITELLM_MASTER_KEY=sk-master-key-change-me

# LiteLLM salt key (used for hashing virtual keys)
LITELLM_SALT_KEY=sk-salt-key-change-me

# Postgres (LiteLLM's database for teams, keys, budgets)
POSTGRES_PASSWORD=litellm-change-me
DATABASE_URL=postgresql://litellm:litellm-change-me@postgres:5432/litellm
